<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RacingSystem.Views.RaceSimulationWindow"
        Title="Simulate Race Result" Width="300" Height="200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CtpBaseBrush}"
        Foreground="{DynamicResource CtpTextBrush}">

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Enter Finishing Position (1-20):" FontWeight="Bold"/>
        <NumericUpDown Name="PosInput" Minimum="1" Maximum="20" Value="1"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="OK" Click="OnOkClick" Background="{DynamicResource CtpGreenBrush}"/>
            <Button Content="Cancel" Click="OnCancelClick" Background="{DynamicResource CtpSurface0Brush}"/>
        </StackPanel>
    </StackPanel>
</Window>
