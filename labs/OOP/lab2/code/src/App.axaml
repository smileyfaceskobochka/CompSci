<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RacingSystem.App"
             xmlns:local="using:RacingSystem"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Catppuccin Mocha Colors -->
        <Color x:Key="CtpBase">#1e1e2e</Color>
        <Color x:Key="CtpMantle">#181825</Color>
        <Color x:Key="CtpCrust">#11111b</Color>
        <Color x:Key="CtpSurface0">#313244</Color>
        <Color x:Key="CtpSurface1">#45475a</Color>
        <Color x:Key="CtpSurface2">#585b70</Color>
        <Color x:Key="CtpOverlay0">#6c7086</Color>
        <Color x:Key="CtpText">#cdd6f4</Color>
        <Color x:Key="CtpSubtext0">#a6adc8</Color>
        <Color x:Key="CtpSubtext1">#bac2de</Color>
        <Color x:Key="CtpMauve">#cba6f7</Color>
        <Color x:Key="CtpPink">#f5c2e7</Color>
        <Color x:Key="CtpBlue">#89b4fa</Color>
        <Color x:Key="CtpSky">#89dceb</Color>
        <Color x:Key="CtpGreen">#a6e3a1</Color>
        <Color x:Key="CtpPeach">#fab387</Color>
        <Color x:Key="CtpRed">#f38ba8</Color>
        <Color x:Key="CtpLavender">#b4befe</Color>

        <Color x:Key="SystemAccentColor">#cba6f7</Color>
        <Color x:Key="SystemAccentColorDark1">#b4befe</Color>
        <Color x:Key="SystemAccentColorDark2">#89b4fa</Color>
        <Color x:Key="SystemAccentColorDark3">#89dceb</Color>
        <Color x:Key="SystemAccentColorLight1">#f5c2e7</Color>
        <Color x:Key="SystemAccentColorLight2">#f38ba8</Color>
        <Color x:Key="SystemAccentColorLight3">#eba0ac</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="CtpBaseBrush" Color="{StaticResource CtpBase}"/>
        <SolidColorBrush x:Key="CtpMantleBrush" Color="{StaticResource CtpMantle}"/>
        <SolidColorBrush x:Key="CtpCrustBrush" Color="{StaticResource CtpCrust}"/>
        <SolidColorBrush x:Key="CtpSurface0Brush" Color="{StaticResource CtpSurface0}"/>
        <SolidColorBrush x:Key="CtpTextBrush" Color="{StaticResource CtpText}"/>
        <SolidColorBrush x:Key="CtpSubtext0Brush" Color="{StaticResource CtpSubtext0}"/>
        <SolidColorBrush x:Key="CtpSubtext1Brush" Color="{StaticResource CtpSubtext1}"/>
        <SolidColorBrush x:Key="CtpMauveBrush" Color="{StaticResource CtpMauve}"/>
        <SolidColorBrush x:Key="CtpPinkBrush" Color="{StaticResource CtpPink}"/>
        <SolidColorBrush x:Key="CtpBlueBrush" Color="{StaticResource CtpBlue}"/>
        <SolidColorBrush x:Key="CtpSkyBrush" Color="{StaticResource CtpSky}"/>
        <SolidColorBrush x:Key="CtpGreenBrush" Color="{StaticResource CtpGreen}"/>
        <SolidColorBrush x:Key="CtpPeachBrush" Color="{StaticResource CtpPeach}"/>
        <SolidColorBrush x:Key="CtpRedBrush" Color="{StaticResource CtpRed}"/>
        <SolidColorBrush x:Key="CtpLavenderBrush" Color="{StaticResource CtpLavender}"/>
        <SolidColorBrush x:Key="CtpOverlay0Brush" Color="{StaticResource CtpOverlay0}"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <!-- Force Mocha colors onto the system theme -->
                <ColorPaletteResources x:Key="Dark" 
                                       Accent="{StaticResource CtpMauve}" 
                                       RegionColor="{StaticResource CtpBase}"
                                       BaseLow="{StaticResource CtpSurface0}"
                                       BaseMediumLow="{StaticResource CtpSurface1}"
                                       BaseMedium="{StaticResource CtpOverlay0}"
                                       BaseMediumHigh="{StaticResource CtpSubtext0}"
                                       BaseHigh="{StaticResource CtpText}"
                                       AltLow="{StaticResource CtpCrust}"
                                       AltMediumLow="{StaticResource CtpMantle}"
                                       AltMedium="{StaticResource CtpBase}"
                                       AltMediumHigh="{StaticResource CtpSurface0}"
                                       AltHigh="{StaticResource CtpSurface1}"
                                       ListLow="{StaticResource CtpSurface0}"
                                       ListMedium="{StaticResource CtpSurface1}" />
            </FluentTheme.Palettes>
        </FluentTheme>

        <!-- Global Control Styles -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource CtpBaseBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource CtpTextBrush}"/>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource CtpMauveBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource CtpBaseBrush}"/>
        </Style>
        
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource CtpSurface0Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CtpSurface1Brush}"/>
        </Style>

        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource CtpSurface0Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CtpSurface1Brush}"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CtpSurface0Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CtpSurface1Brush}"/>
        </Style>

        <!-- Override ListBoxItem selection -->
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#313244" /> <!-- CtpSurface0 -->
        </Style>
    </Application.Styles>
</Application>