<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RacingSystem.ViewModels"
        xmlns:core="using:RacingSystem.Core"
        x:Class="RacingSystem.Views.TeamComparisonWindow"
        x:DataType="vm:ComparisonViewModel"
        Title="Team Comparison" Width="600" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CtpBaseBrush}"
        Foreground="{DynamicResource CtpTextBrush}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="Side-by-Side Comparison" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, *">
            <!-- Team A -->
            <Border Grid.Column="0" Background="{DynamicResource CtpMantleBrush}" Padding="15" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding TeamA.TeamName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource CtpMauveBrush}"/>
                    <TextBlock Text="{Binding TeamA.SeriesName}" FontSize="12" Opacity="0.7"/>
                    <Separator/>
                    <TextBlock Text="{Binding TeamA.ChampionshipPoints, StringFormat='Points: {0}'}"/>
                    <TextBlock Text="{Binding TeamA.RaceWins, StringFormat='Wins: {0}'}"/>
                    <TextBlock Text="{Binding TeamA.Podiums, StringFormat='Podiums: {0}'}"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Column="1" Text="VS" VerticalAlignment="Center" Margin="20" FontSize="24" FontWeight="Black" Foreground="{DynamicResource CtpPinkBrush}"/>

            <!-- Team B -->
            <Border Grid.Column="2" Background="{DynamicResource CtpMantleBrush}" Padding="15" CornerRadius="10">
                <StackPanel Spacing="10">
                    <ComboBox ItemsSource="{Binding AvailableTeams}" SelectedItem="{Binding TeamB}" HorizontalAlignment="Stretch" Background="Transparent" Padding="0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="core:FormulaTeam">
                                <TextBlock Text="{Binding TeamName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource CtpMauveBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="{Binding TeamB.SeriesName}" FontSize="12" Opacity="0.7"/>
                    <Separator/>
                    <TextBlock Text="{Binding TeamB.ChampionshipPoints, StringFormat='Points: {0}'}"/>
                    <TextBlock Text="{Binding TeamB.RaceWins, StringFormat='Wins: {0}'}"/>
                    <TextBlock Text="{Binding TeamB.Podiums, StringFormat='Podiums: {0}'}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource CtpSurface0Brush}" Margin="0,20,0,0" Padding="15" CornerRadius="5">
            <TextBlock Text="{Binding ComparisonResult}" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource CtpYellowBrush}"/>
        </Border>
    </Grid>
</Window>
