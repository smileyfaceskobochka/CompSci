<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RacingSystem.ViewModels"
        xmlns:core="using:RacingSystem.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="RacingSystem.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Formula Racing Management System"
        Background="{DynamicResource CtpBaseBrush}">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{DynamicResource CtpMantleBrush}"
                BoxShadow="0 2 8 2 #22000000" Padding="18,14">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="🏎  Formula Racing Management System"
                               FontSize="18" FontWeight="Black"
                               Foreground="{DynamicResource CtpMauveBrush}"/>
                    <TextBlock Text="F1 · F2 · Formula E — 2026 Season"
                               FontSize="11" Foreground="{DynamicResource CtpOverlay1Brush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Teams" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource CtpSubtext0Brush}"/>
                    <ToggleSwitch IsChecked="{Binding IsStandingsView}"
                                  OffContent="" OnContent=""
                                  Foreground="{DynamicResource CtpSubtext1Brush}"/>
                    <TextBlock Text="Standings" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource CtpSubtext0Brush}"/>
                    <ToggleSwitch IsChecked="{Binding IsDriverStandingsView}"
                                  OffContent="" OnContent=""
                                  Foreground="{DynamicResource CtpSubtext1Brush}"/>
                    <TextBlock Text="Driver Standings" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource CtpSubtext0Brush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main Content ── -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 320">

            <!-- List Panel -->
            <Border Grid.Column="0" Background="{DynamicResource CtpCrustBrush}" Margin="0">
                <ListBox ItemsSource="{Binding ListItems}"
                         SelectedItem="{Binding SelectedTeam}"
                         Background="Transparent"
                         Margin="12,12,6,12">
                    <ListBox.DataTemplates>

                        <!-- Series Header (delimiter) -->
                        <DataTemplate x:DataType="vm:SeriesHeader">
                            <Border Padding="10,18,10,6" Background="Transparent">
                                <StackPanel Spacing="2">
                                    <Rectangle Height="1" Fill="{DynamicResource CtpSurface1Brush}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="Black" FontSize="13"
                                               Foreground="{DynamicResource CtpSkyBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>

                        <!-- Team Card -->
                        <DataTemplate x:DataType="core:FormulaTeam">
                            <Border Padding="12,10" Margin="0,2"
                                    Background="{DynamicResource CtpSurface0Brush}"
                                    CornerRadius="6">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <TextBlock Text="{Binding TeamName}"
                                                   FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource CtpLavenderBrush}"/>
                                        <TextBlock Text="{Binding Summary}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource CtpSubtext0Brush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center" Spacing="6">
                                        <TextBlock Text="{Binding ChampionshipPoints}"
                                                   FontSize="18" FontWeight="Black"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource CtpPeachBrush}"/>
                                        <Button Content="✕"
                                                FontSize="11" Width="26" Height="26"
                                                Padding="0"
                                                Background="{DynamicResource CtpRedBrush}"
                                                Foreground="{DynamicResource CtpBaseBrush}"
                                                CornerRadius="4"
                                                Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).DeleteTeamCommand}"
                                                CommandParameter="{Binding}"
                                                Click="OnInlineDeleteClick"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>

                        <!-- Driver Card (shown in Driver Standings mode) -->
                        <DataTemplate x:DataType="core:FormulaDriver">
                            <Border Padding="12,9" Margin="0,2"
                                    Background="{DynamicResource CtpSurface0Brush}"
                                    CornerRadius="6">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontWeight="Bold" FontSize="13"
                                                   Foreground="{DynamicResource CtpTealBrush}"/>
                                        <TextBlock Text="{Binding DisplayString}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource CtpSubtext0Brush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Points}"
                                               FontSize="18" FontWeight="Black"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource CtpYellowBrush}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>

                    </ListBox.DataTemplates>
                </ListBox>
            </Border>

            <!-- ── Details Panel ── -->
            <Border Grid.Column="1" Background="{DynamicResource CtpMantleBrush}"
                    Margin="0" Padding="20,18">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <TextBlock Text="Team Details" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource CtpSkyBrush}"/>

                        <!-- When team selected -->
                        <StackPanel IsVisible="{Binding SelectedTeam, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Spacing="12">

                            <TextBlock Text="{Binding SelectedTeam.TeamName}"
                                       FontSize="18" FontWeight="Black"
                                       Foreground="{DynamicResource CtpLavenderBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- Stats grid -->
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                <Border Grid.Column="0" Grid.Row="0"
                                        Background="{DynamicResource CtpSurface0Brush}"
                                        CornerRadius="6" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="Points" Foreground="{DynamicResource CtpSubtext0Brush}" FontSize="11"/>
                                        <TextBlock Text="{Binding SelectedTeam.ChampionshipPoints}"
                                                   FontSize="26" FontWeight="Black"
                                                   Foreground="{DynamicResource CtpPeachBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Grid.Row="0"
                                        Background="{DynamicResource CtpSurface0Brush}"
                                        CornerRadius="6" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="Wins" Foreground="{DynamicResource CtpSubtext0Brush}" FontSize="11"/>
                                        <TextBlock Text="{Binding SelectedTeam.RaceWins}"
                                                   FontSize="26" FontWeight="Black"
                                                   Foreground="{DynamicResource CtpGreenBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="0" Grid.Row="1"
                                        Background="{DynamicResource CtpSurface0Brush}"
                                        CornerRadius="6" Padding="12,10" Margin="0,8,4,0">
                                    <StackPanel>
                                        <TextBlock Text="Podiums" Foreground="{DynamicResource CtpSubtext0Brush}" FontSize="11"/>
                                        <TextBlock Text="{Binding SelectedTeam.Podiums}"
                                                   FontSize="26" FontWeight="Black"
                                                   Foreground="{DynamicResource CtpYellowBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Grid.Row="1"
                                        Background="{DynamicResource CtpSurface0Brush}"
                                        CornerRadius="6" Padding="12,10" Margin="4,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Series" Foreground="{DynamicResource CtpSubtext0Brush}" FontSize="11"/>
                                        <TextBlock Text="{Binding SelectedTeam.SeriesName}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource CtpMauveBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Drivers section -->
                            <TextBlock Text="Drivers" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource CtpSkyBrush}" Margin="0,4,0,0"/>
                            <ItemsControl ItemsSource="{Binding SelectedTeam.Drivers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="core:FormulaDriver">
                                        <Border Background="{DynamicResource CtpSurface1Brush}"
                                                CornerRadius="5" Padding="10,7" Margin="0,2">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding FullName}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource CtpTealBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Points, StringFormat='{}Pts: {0}'}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource CtpYellowBrush}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Rectangle Height="1" Fill="{DynamicResource CtpSurface1Brush}" Margin="0,6"/>

                            <Button Content="🏁  Simulate Race"
                                    HorizontalAlignment="Stretch" Click="OnSimulateRaceClick"
                                    Background="{DynamicResource CtpBlueBrush}"
                                    Foreground="{DynamicResource CtpBaseBrush}"
                                    FontWeight="Bold" CornerRadius="6"/>
                            <Button Content="⚖  Compare Teams"
                                    HorizontalAlignment="Stretch" Click="OnCompareClick"
                                    Background="{DynamicResource CtpMauveBrush}"
                                    Foreground="{DynamicResource CtpBaseBrush}"
                                    FontWeight="Bold" CornerRadius="6"/>
                            <Button Content="✎  Edit Team"
                                    HorizontalAlignment="Stretch" Click="OnEditTeamClick"
                                    Background="{DynamicResource CtpSurface1Brush}"
                                    CornerRadius="6"/>
                            <Button Content="🗑  Delete Team"
                                    HorizontalAlignment="Stretch"
                                    Click="OnDeleteSelectedClick"
                                    Background="{DynamicResource CtpRedBrush}"
                                    Foreground="{DynamicResource CtpBaseBrush}"
                                    FontWeight="Bold" CornerRadius="6"/>
                        </StackPanel>

                        <TextBlock Text="Select a team to view details"
                                   IsVisible="{Binding SelectedTeam, Converter={x:Static ObjectConverters.IsNull}}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Margin="0,80" Foreground="{DynamicResource CtpOverlay0Brush}"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Footer Actions ── -->
        <Border Grid.Row="2" Background="{DynamicResource CtpMantleBrush}"
                BorderBrush="{DynamicResource CtpSurface0Brush}" BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="+ Add Team" Click="OnAddTeamClick" Width="110"
                        Background="{DynamicResource CtpGreenBrush}"
                        Foreground="{DynamicResource CtpBaseBrush}"
                        FontWeight="Bold" CornerRadius="6"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
